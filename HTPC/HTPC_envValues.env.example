# Copy this file to HTPC_envValues.env and adjust values for your environment.

MOVIE_FOLDER=/path/to/media/movies
TV_FOLDER=/path/to/media/tv
INCOMPLETE_DOWNLOADS=/path/to/downloads/incomplete
COMPLETE_DOWNLOADS=/path/to/downloads/complete
WATCH_FOLDER=/path/to/downloads/watch
EBOOK_FOLDER=/path/to/media/ebooks
COMIC_FOLDER=/path/to/media/comics
CONFIG_ROOT=/path/to/config
KIBANA_HOST=192.168.1.20
BEATS_HOST=192.168.1.10
HTPC_DOCKER_COMPOSE_ROOT=/path/to/arrs-compose-setup
